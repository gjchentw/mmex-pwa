# Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# WARNING: every VITE_* value is inlined into the client bundle at build time and
# is therefore PUBLICLY READABLE by anyone who loads the app. These are
# identifiers, not secrets. Never put an OAuth client *secret* in this file --
# this app is client-only and has no backend to keep one in.
#
# Restrict these credentials by HTTP referrer / authorized origin in the
# Google Cloud console instead. That, not secrecy, is what protects them.

# OAuth 2.0 Client ID -- Google Cloud console > APIs & Services > Credentials
# > OAuth 2.0 Client IDs. Used for Google Sign-In.
VITE_GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# API key -- Credentials > API keys. Used by the Google Picker / Drive API
# when choosing a database file from Drive.
VITE_GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Cloud project number (not the project ID). The Picker API requires it
# as the "app id".
VITE_GOOGLE_APP_ID=000000000000
