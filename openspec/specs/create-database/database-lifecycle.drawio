          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Probe OPFS → OPFS Error -->
        <mxCell id="e4" value="error" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="n2" target="n5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OPFS Empty → Init New DB -->
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n3" target="n6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Init New DB → New DB Wizard -->
        <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n6" target="n9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OPFS Has DB → Version Check -->
        <mxCell id="e7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n4" target="n7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Version Check → Current -->
        <mxCell id="e8" value="v == latest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="n7" target="n10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Version Check → Run Upgrades -->
        <mxCell id="e9" value="v &lt; latest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="n7" target="n11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Current → Ready -->
