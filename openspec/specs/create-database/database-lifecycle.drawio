          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Ready → Manual New DB -->
        <mxCell id="e13" value="User: New DB" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n12" target="n13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Manual New DB → Confirm Destroy -->
        <mxCell id="e14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n13" target="n14">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Confirm Destroy → Destroy OPFS -->
        <mxCell id="e15" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="n14" target="n15">
          <mxGeometry relative="1" as="geometry" />
